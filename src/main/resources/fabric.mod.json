{
    "schemaVersion": 1,
    "id": "mcapi",
    "version": "${version}",
    "name": "ApiBridge",
    "description": "HTTP API to control Minecraft entirely from terminal/CLI",
    "authors": ["DuyAnh662"],
    "contact": {
        "homepage": "https://github.com/DuyAnh662/mc-api-mod",
        "sources": "https://github.com/DuyAnh662/mc-api-mod"
    },
    "license": "MIT",
    "icon": "assets/mcapi/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": ["com.mcapi.McApiMod"],
        "client": ["com.mcapi.McApiClient"]
    },
    "accessWidener": "mcapi.accesswidener",
    "depends": {
        "fabricloader": ">=${loader_version}",
        "minecraft": ">=26.2 <=26.2",
        "java": ">=25",
        "fabric-api": "*"
    }
}
